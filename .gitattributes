# Normalize line endings for all text files to LF on commit
* text=auto eol=lf

# Java source files
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.sql text eol=lf

# Windows scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files — no line ending conversion
*.jar binary
*.rar binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.ttf binary
*.otf binary
